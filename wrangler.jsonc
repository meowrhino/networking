{
  // el pequeño networker — Worker de solo assets estáticos (sin código de servidor)
  // sirve index.html + css/js/sw/iconos directamente desde la raíz del repo.
  "name": "networking",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "./"
  },
  // dominio personalizado: al desplegar, Cloudflare crea el DNS + certificado automáticamente
  "routes": [
    { "pattern": "networking.meowrhino.studio", "custom_domain": true }
  ]
}
